{
  "name": "wp-webjs",
  "version": "1.0.0",
  "description": "WhatsApp-OpenAI Integration POC - Receives WhatsApp messages and responds using OpenAI",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "dev": "node --watch server.js",
    "start": "node server.js",
    "clean": "node -e \"require('fs').rmSync('./.wwebjs_auth', {recursive:true, force:true})\"",
    "logs": "tail -f logs/app.log"
  },
